# =============================================================================
# AutoDocs — Variables d'environnement
# =============================================================================
# Copier ce fichier en `.env` (jamais commité) et remplir avec vos valeurs.
# IMPORTANT : seules les variables préfixées VITE_ sont exposées au navigateur.
# Toutes les autres restent uniquement côté serveur (api/*.ts).

# -----------------------------------------------------------------------------
# CÔTÉ CLIENT (exposées au navigateur via Vite — préfixe VITE_ obligatoire)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# Optionnel : clé publique Stripe (si Stripe.js client-side)
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# -----------------------------------------------------------------------------
# CÔTÉ SERVEUR UNIQUEMENT (api/*.ts) — JAMAIS exposer au front
# -----------------------------------------------------------------------------
# Supabase service role : bypass RLS, à protéger absolument.
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# OpenAI (analyse OCR CNI)
OPENAI_API_KEY=sk-proj-...

# Stripe (Checkout, webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...
